class MainActivity : ComponentActivity() {
    
    private val permissionLauncher = registerForActivityResult(
        ActivityResultContracts.RequestMultiplePermissions()
    ) { permissions ->
        val allGranted = permissions.entries.all { it.value }
        if (allGranted) {
            Toast.makeText(this, "Permissions granted. You can start the service.", Toast.LENGTH_SHORT).show()
        }
    }
    
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        
    // Register SMS receiver removed - use static receiver in manifest only
        
        setContent {
            OperitPluginTheme {
                Surface(
                    modifier = Modifier.fillMaxSize(),
                    color = MaterialTheme.colorScheme.background
                ) {
                    MainScreen(
                        onStartService = { startApiService() },
                        onStopService = { stopApiService() },
                        onOpenPermissions = { openPermissionsSettings() },
                        isServiceRunning = { OperitApiService.isRunning }
                    )
                }
            }
        }
    }
    
    override fun onDestroy() {
        super.onDestroy()
    }
    
    private fun openPermissionsSettings() {
        val intent = Intent(Settings.ACTION_APPLICATION_DETAILS_SETTINGS).apply {
            data = Uri.parse("package:$packageName")
        }
        startActivity(intent)
    }
    
    private fun startApiService() {
        val intent = Intent(this, OperitApiService::class.java).apply {
            action = OperitApiService.ACTION_START
        }
        ContextCompat.startForegroundService(this, intent)
        Toast.makeText(this, "Operit API Service started", Toast.LENGTH_SHORT).show()
    }
    
    private fun stopApiService() {
        val intent = Intent(this, OperitApiService::class.java).apply {
            action = OperitApiService.ACTION_STOP
        }
        startService(intent)
        Toast.makeText(this, "Operit API Service stopped", Toast.LENGTH_SHORT).show()
    }
}

@Composable
fun MainScreen(
    onStartService: () -> Unit,
    onStopService: () -> Unit,
    onOpenPermissions: () -> Unit,
    isServiceRunning: () -> Boolean
) {
    var serviceRunning by remember { mutableStateOf(isServiceRunning()) }
    var pulseAnim by remember { mutableStateOf(1f) }
    
    // Animation for the status indicator
    LaunchedEffect(serviceRunning) {
        while (serviceRunning) {
            pulseAnim = 0.6f
            delay(500)
            pulseAnim = 1f
            delay(500)
            pulseAnim = 0.6f
            delay(500)
            pulseAnim = 1f
            delay(500)
        }
    }
    
    // Poll service status
    LaunchedEffect(Unit) {
        while (true) {
            serviceRunning = isServiceRunning()
            delay(500)
        }
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .verticalScroll(rememberScrollState())
            .padding(16.dp),
        horizontalAlignment = Alignment.CenterHorizontally
    ) {
        // Header
        HeaderCard()
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Status Card - Enhanced with real-time indicator
        StatusCard(serviceRunning, pulseAnim)
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Connection Info
        if (serviceRunning) {
            ConnectionInfoCard()
            Spacer(modifier = Modifier.height(16.dp))
        }
        
        // Control Buttons
        ControlButtons(serviceRunning, onStartService, onStopService, onOpenPermissions)
        
        Spacer(modifier = Modifier.height(24.dp))
        
        // Available APIs
        ApiEndpointsCard()
    }
}

