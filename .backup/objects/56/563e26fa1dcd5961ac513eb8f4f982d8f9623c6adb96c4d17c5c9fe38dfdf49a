@Composable
fun StatusCard(running: Boolean, pulseAnim: Float) {
    val statusColor = if (running) Color(0xFF4CAF50) else Color(0xFFF44336)
    val statusBg = if (running) Color(0xFF1B5E20).copy(alpha = 0.2f) else Color(0xFFB71C1C).copy(alpha = 0.2f)
    
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(containerColor = statusBg),
        shape = RoundedCornerShape(12.dp)
    ) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(20.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            // Pulsing indicator
            Box(
                modifier = Modifier
                    .size(16.dp)
                    .background(
                        color = statusColor.copy(alpha = if (running) pulseAnim else 1f),
                        shape = RoundedCornerShape(50)
                    )
            )
            Spacer(modifier = Modifier.width(16.dp))
            Column {
                Text(
                    text = if (running) "● Server Running" else "○ Server Stopped",
                    style = MaterialTheme.typography.titleLarge,
                    color = statusColor
                )
                if (running) {
                    Text(
                        text = "Accepting connections on localhost:8765",
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
            }
        }
    }
}

